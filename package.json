{
  "name": "current",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "serve": "node server/index.js",
    "serve:static": "npx serve dist --single --listen $PORT",
    "deploy": "npm run build:web && npm run serve",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "expo": "~54.0.33",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.19.13",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react-native-web": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "private": true
}
