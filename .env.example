# Server-only variables. None of these are exposed to the client bundle —
# they are read by the Node process in server/index.js. Do NOT prefix any of
# them with EXPO_PUBLIC_ or they will leak into the web bundle.

# Required for /api/generate. Without it, the API returns 503 and the client
# falls back to local static lines.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Defaults to a fast Claude model.
# LLM_MODEL=claude-haiku-4-5-20251001

# Optional. Per-IP requests per minute on /api/generate. Default 20.
# LLM_RATE_LIMIT_PER_MIN=20

# Optional. Port. Railway sets this automatically.
# PORT=3000

# Optional, client-only. Set this in local Expo dev so the web bundle can
# reach the API on a different port. In production, leave empty so /api/*
# resolves on the same origin as the static bundle.
# EXPO_PUBLIC_API_BASE=http://localhost:3000

# ─── Auth ────────────────────────────────────────────────────────────────────
# When DATABASE_URL is set, /api/auth/* is enabled and the web client renders
# a login screen before the app. When unset, auth is disabled and the app
# behaves as it did before (LLM endpoints stay open).

# Required for auth. Railway provides this automatically when Postgres is
# attached to the service. The server creates the `users` table at startup.
# DATABASE_URL=postgres://USER:PASS@HOST:PORT/DBNAME

# Strongly recommended. Used to sign session cookies. In production set this
# to a long random string (32+ chars). In dev a fallback is used and a
# warning is logged. If unset in production, sessions will not survive
# restarts (an ephemeral random secret is generated per process).
# SESSION_SECRET=change-me-to-a-long-random-string

# Optional. If both are set AND no users exist, the admin user is seeded on
# first startup. Otherwise registration is OPEN until the first user is
# created, then closed (single-user mode). Use these for a closed deploy
# where you do not want any visitor to register.
# CURRENT_ADMIN_USERNAME=luke
# CURRENT_ADMIN_PASSWORD=at-least-6-chars

# Optional. Keep registration open after the first user exists. Default off.
# CURRENT_OPEN_REGISTRATION=true
