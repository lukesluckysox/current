# Server-only variables. None of these are exposed to the client bundle —
# they are read by the Node process in server/index.js. Do NOT prefix any of
# them with EXPO_PUBLIC_ or they will leak into the web bundle.

# Required for /api/generate. Without it, the API returns 503 and the client
# falls back to local static lines.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Defaults to a fast Claude model.
# LLM_MODEL=claude-haiku-4-5-20251001

# Optional. Per-IP requests per minute on /api/generate. Default 30.
# LLM_RATE_LIMIT_PER_MIN=30

# Optional. Port. Railway sets this automatically.
# PORT=3000

# Optional, client-only. Set this in local Expo dev so the web bundle can
# reach the API on a different port. In production, leave empty so /api/*
# resolves on the same origin as the static bundle.
# EXPO_PUBLIC_API_BASE=http://localhost:3000

# ─── Auth ────────────────────────────────────────────────────────────────────
# Auth is REQUIRED in production. The web client always shows a login screen
# in production, and /api/* generation endpoints require a valid session.
# If DATABASE_URL is missing in production, the app shows an "auth
# unavailable" message rather than rendering unauthenticated.

# Required in production. Postgres connection string. Railway provides this
# automatically when Postgres is attached to the service. The server creates
# the `users` table at startup.
DATABASE_URL=postgres://USER:PASS@HOST:PORT/DBNAME

# Required/recommended in production. Used to sign session cookies. Set this
# to a long random string (32+ chars). If unset in production, sessions will
# not survive restarts (an ephemeral random secret is generated per process)
# and a warning is logged.
SESSION_SECRET=change-me-to-a-long-random-string

# Registration is OPEN by default — anyone with access to the URL can create
# an account, and multiple users are supported. To CLOSE registration on a
# deployed instance (e.g. after seeding your accounts), set this to false:
# CURRENT_OPEN_REGISTRATION=false

# Optional. If both are set AND no users exist, the admin user is seeded on
# first startup. Useful for guaranteeing one known account exists. Does not
# disable open registration on its own; combine with
# CURRENT_OPEN_REGISTRATION=false to lock the instance to seeded accounts.
# CURRENT_ADMIN_USERNAME=luke
# CURRENT_ADMIN_PASSWORD=at-least-6-chars

# Local-dev escape hatch. ONLY honored when NODE_ENV != 'production'. Skips
# the login gate entirely so you can run `npm run web` against a bare
# server with no Postgres. NEVER bypasses auth in production deployments.
# CURRENT_AUTH_DISABLED=true
