{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --legacy-peer-deps && npm run build:web"
  },
  "deploy": {
    "startCommand": "node_modules/.bin/serve dist --single --listen $PORT",
    "restartPolicyType": "ON_FAILURE"
  }
}
