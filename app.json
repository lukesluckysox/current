{
  "expo": {
    "name": "Swell",
    "slug": "swell",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Swell",
      "shortName": "Swell",
      "description": "A pocket creative instrument for turning passing states into lines worth keeping.",
      "backgroundColor": "#0A1628",
      "themeColor": "#0A1628",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-font",
      "expo-sqlite"
    ]
  }
}
